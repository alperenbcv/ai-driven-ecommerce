option_settings:
  aws:elasticbeanstalk:application:environment:
    SPRING_PROFILES_ACTIVE: "docker"

    SPRING_DATASOURCE_URL:      "jdbc:postgresql://${RDS_HOSTNAME}:${RDS_PORT}/ecommerce"
    SPRING_DATASOURCE_USERNAME: "${RDS_USERNAME}"
    SPRING_DATASOURCE_PASSWORD: "${RDS_PASSWORD}"

    REDIS_HOST: "${ELASTICACHE_HOST}"
    REDIS_PORT: "6379"

    SPRING_RABBITMQ_HOST:     "rabbitmq"
    SPRING_RABBITMQ_PORT:     "5672"
    SPRING_RABBITMQ_USERNAME: "ecommerce"
    SPRING_RABBITMQ_PASSWORD: "ecommerce123"

    SPRING_NEO4J_URI:               "bolt://neo4j:7687"
    SPRING_NEO4J_AUTHENTICATION_USERNAME: "neo4j"
    SPRING_NEO4J_AUTHENTICATION_PASSWORD: "ecommerce123"

    JWT_SECRET: "${JWT_SECRET}"

    OPENAI_API_KEY:        "${OPENAI_API_KEY}"
    CLOUDINARY_CLOUD_NAME: "${CLOUDINARY_CLOUD_NAME}"
    CLOUDINARY_API_KEY:    "${CLOUDINARY_API_KEY}"
    CLOUDINARY_API_SECRET: "${CLOUDINARY_API_SECRET}"
    IYZICO_API_KEY:        "${IYZICO_API_KEY}"
    IYZICO_SECRET_KEY:     "${IYZICO_SECRET_KEY}"
    IYZICO_BASE_URL:       "https://sandbox-api.iyzipay.com"

  aws:autoscaling:launchconfiguration:
    InstanceType: "t3.medium"
    IamInstanceProfile: "aws-elasticbeanstalk-ec2-role"

  aws:elasticbeanstalk:environment:
    EnvironmentType: "SingleInstance"    # LoadBalanced → ek ELB ücreti; demo için single
    ServiceRole:     "aws-elasticbeanstalk-service-role"

  aws:autoscaling:asg:
    MinSize: "1"
    MaxSize: "1"

  # TCP check: port açık mı bakar, HTTP 200 beklemez
  # Servisler tamamen ayağa kalkmadan önce HTTP check başarısız olur
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: "TCP:80"

  aws:elasticbeanstalk:healthreporting:system:
    SystemType: "enhanced"

  aws:rds:dbinstance:
    DBEngine:           "postgres"
    DBEngineVersion:    "16"
    DBInstanceClass:    "db.t3.micro"     # Free tier
    DBAllocatedStorage: "20"
    MultiAZDatabase:    "false"
    DBDeletionPolicy:   "Snapshot"
